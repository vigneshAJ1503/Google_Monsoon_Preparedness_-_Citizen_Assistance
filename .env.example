# Environment Variables for Monsoon Preparedness App
# Copy this to .env and fill in your values

# Groq AI (Free tier: 14,400 req/day for Llama 3.1 8B)
# Get free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Gemini AI (Optional - keep for fallback)
GEMINI_API_KEY=your_gemini_api_key_here

# Database
POSTGRES_USER=monsoonprep
POSTGRES_PASSWORD=monsoonprep_dev_password
POSTGRES_DB=monsoonprep
DATABASE_URL=postgresql+asyncpg://monsoonprep:monsoonprep_dev_password@postgres:5432/monsoonprep

# Redis
REDIS_URL=redis://redis:6379/0

# Application
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
LOG_LEVEL=INFO

# Weather API (Open-Meteo - no key needed)
WEATHER_CACHE_TTL_SECONDS=300
FORECAST_CACHE_TTL_SECONDS=1800

# Alert Engine
ALERT_COOLDOWN_MINUTES=180
ALERT_DATA_MAX_AGE_SECONDS=600

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:80
